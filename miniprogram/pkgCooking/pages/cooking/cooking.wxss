/* cooking.wxss */
page {
  height: 100vh;
  background-color: #2c2c2c;
}

.scrollarea {
  height: 100vh;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 30rpx 8rpx;
}

.section-title-icon {
  width: 44rpx;
  height: 44rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #e8d5a3;
}

/* 食谱网格 */
.dishes-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  padding: 20rpx 16rpx;
}

.dish-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 4rpx;
  border-radius: 8rpx;
}

.dish-cell:active {
  background-color: rgba(232, 213, 163, 0.2);
}

.dish-icon {
  width: 90rpx;
  height: 90rpx;
}

.dish-name {
  font-size: 20rpx;
  color: #e8d5a3;
  margin-top: 8rpx;
  text-align: center;
  word-break: break-all;
}

/* ==================== 弹窗 ==================== */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-container {
  width: 85%;
  max-height: 80vh;
  background-color: #2c2c2c;
  border-radius: 20rpx;
  border: 3rpx solid rgba(232, 213, 163, 0.4);
  overflow: hidden;
}

.popup-header {
  background-color: #3c3730;
  padding: 28rpx 0 20rpx;
  text-align: center;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.3);
}

.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #e8d5a3;
}

.popup-image-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 20rpx;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.15);
}

.popup-image {
  width: 200rpx;
  height: 200rpx;
}

.popup-icon-img {
  width: 80rpx;
  height: 80rpx;
  margin-top: 12rpx;
}

.popup-section-header {
  background-color: rgba(232, 213, 163, 0.1);
  padding: 14rpx 0;
  text-align: center;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.2);
  border-top: 2rpx solid rgba(232, 213, 163, 0.2);
}

.popup-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #e8d5a3;
}

/* 食物属性 */
.food-stats-row {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  padding: 24rpx 0;
}

.food-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.food-stat-icon {
  width: 64rpx;
  height: 64rpx;
}

.food-stat-val {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.food-type-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 0 0 20rpx;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.15);
}

.food-type-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #e8d5a3;
}

.food-type-val {
  font-size: 24rpx;
  color: #ccc;
}

/* 烹饪条件 */
.cook-info {
  padding: 20rpx 28rpx;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.15);
}

.cook-req-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.cook-req-tag {
  font-size: 22rpx;
  color: #ccc;
  background: rgba(232, 213, 163, 0.1);
  border: 1rpx solid rgba(232, 213, 163, 0.2);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  white-space: nowrap;
}

.cook-info-row {
  display: flex;
  gap: 40rpx;
  margin-top: 8rpx;
}

.cook-info-sub {
  font-size: 22rpx;
  color: #999;
}

.special-req {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.special-req-icon {
  width: 48rpx;
  height: 48rpx;
}

.special-req-name {
  font-size: 20rpx;
  color: #ccc;
  margin-right: 4rpx;
}

.special-req-cond {
  font-size: 24rpx;
  color: #e8d5a3;
}

/* 烹饪范例 */
.examples-list {
  padding: 16rpx 20rpx;
}

.example-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(232, 213, 163, 0.08);
}

.example-row:last-child {
  border-bottom: none;
}

.example-ingredients {
  display: flex;
  gap: 8rpx;
}

.example-ing {
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.example-ing-icon {
  width: 56rpx;
  height: 56rpx;
}

.example-arrow {
  font-size: 24rpx;
  color: #e8d5a3;
  margin: 0 16rpx;
}

.example-result {
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.example-result-icon {
  width: 56rpx;
  height: 56rpx;
}

/* 关闭按钮 */
.popup-close {
  padding: 24rpx 0;
  text-align: center;
  border-top: 2rpx solid rgba(232, 213, 163, 0.2);
  background-color: #3c3730;
}

.popup-close:active {
  background-color: rgba(232, 213, 163, 0.15);
}

.popup-close-text {
  font-size: 28rpx;
  color: #e8d5a3;
  font-weight: 500;
}

.bottom-spacer {
  height: 140rpx;
}
