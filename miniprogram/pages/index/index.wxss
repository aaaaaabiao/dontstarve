/**index.wxss**/
page {
  height: 100vh;
  background-color: #2c2c2c;
}

.scrollarea {
  height: 100vh;
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 16rpx;
  background-color: #3c3730;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.2);
}

.category-item {
  width: 10%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.category-item.active {
  background-color: rgba(232, 213, 163, 0.3);
  border: 2rpx solid #e8d5a3;
}

.category-icon {
  width: 52rpx;
  height: 52rpx;
}

/* 分类标题 */
.section-title {
  padding: 24rpx 30rpx 8rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #e8d5a3;
}

/* 物品滚动区 */
.items-scroll {
  height: 450rpx;
}

/* 物品网格 */
.items-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  padding: 20rpx 16rpx;
}

.item-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 4rpx;
  border-radius: 8rpx;
}

.item-cell.item-active {
  background-color: rgba(232, 213, 163, 0.2);
  border: 2rpx solid #e8d5a3;
}

.item-icon {
  width: 90rpx;
  height: 90rpx;
}

.item-name {
  font-size: 20rpx;
  color: #e8d5a3;
  margin-top: 8rpx;
  text-align: center;
  word-break: break-all;
}

/* 子分类 */
.sub-section {
  margin-bottom: 16rpx;
}

.sub-header {
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid rgba(232, 213, 163, 0.15);
}

.sub-icon {
  width: 56rpx;
  height: 56rpx;
}

/* 合成配方面板 */
.recipe-panel {
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.recipe-card {
  background-color: #3c3730;
  border-radius: 16rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.recipe-header {
  background-color: rgba(232, 213, 163, 0.1);
  padding: 16rpx 0;
  text-align: center;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.2);
}

.recipe-header-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #e8d5a3;
}

/* 材料 > 产物 */
.recipe-craft {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
}

.recipe-ingredients {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ingredient {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ingredient-icon {
  width: 70rpx;
  height: 70rpx;
}

.ingredient-qty {
  position: absolute;
  bottom: 4rpx;
  right: 8rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 0 4rpx rgba(0,0,0,0.8);
}

.recipe-arrow {
  font-size: 32rpx;
  color: #e8d5a3;
  margin: 0 24rpx;
}

.recipe-result {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-icon {
  width: 70rpx;
  height: 70rpx;
}

/* 描述 */
.recipe-desc {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  padding: 0 20rpx 24rpx;
  font-style: italic;
}

/* 分类 & 解锁 */
.recipe-meta {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  padding: 20rpx 0;
  border-top: 2rpx solid rgba(232, 213, 163, 0.15);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #e8d5a3;
}

.meta-icon {
  width: 56rpx;
  height: 56rpx;
}
