/**index.wxss**/
page {
  height: 100vh;
  background-color: #2c2c2c;
  overflow: hidden;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-top: var(--status-bar-height, 20px);
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 16rpx;
  background-color: #3c3730;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.2);
}

.category-item {
  width: 10%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.category-item.active {
  background-color: rgba(232, 213, 163, 0.3);
  border: 2rpx solid #e8d5a3;
}

.category-icon {
  width: 52rpx;
  height: 52rpx;
}

/* 分类标题 */
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx 8rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #e8d5a3;
}

.section-hint {
  font-size: 22rpx;
  color: rgba(232, 213, 163, 0.5);
}

/* 物品列表区（填满剩余空间，内部可滚动） */
.items-scroll {
  flex: 1;
  overflow: hidden;
}

/* 底部留白，避免被 tab-bar 遮挡 */
.bottom-spacer {
  height: calc(140rpx + env(safe-area-inset-bottom));
}

/* 物品网格 */
.items-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  padding: 20rpx 16rpx;
}

.item-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 4rpx;
  border-radius: 8rpx;
}

.item-cell.item-active {
  background-color: rgba(232, 213, 163, 0.2);
  border: 2rpx solid #e8d5a3;
}

.item-icon {
  width: 90rpx;
  height: 90rpx;
}

.item-name {
  font-size: 20rpx;
  color: #e8d5a3;
  margin-top: 8rpx;
  text-align: center;
  word-break: break-all;
}

/* 子分类图标行 */
.sub-category-row {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 16rpx 8rpx;
  background-color: #33302a;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.15);
}

.sub-category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.sub-category-item.sub-active {
  background-color: rgba(232, 213, 163, 0.3);
  border: 2rpx solid #e8d5a3;
}

.sub-category-icon {
  width: 52rpx;
  height: 52rpx;
}

/* 合成配方面板 */
.recipe-panel {
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.recipe-card {
  background-color: #3c3730;
  border-radius: 16rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.recipe-header {
  background-color: rgba(232, 213, 163, 0.1);
  padding: 16rpx 0;
  text-align: center;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.2);
}

.recipe-header-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #e8d5a3;
}

/* 材料 > 产物 */
.recipe-craft {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
}

.recipe-ingredients {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ingredient {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ingredient-icon {
  width: 70rpx;
  height: 70rpx;
}

.ingredient-qty {
  position: absolute;
  bottom: 4rpx;
  right: 8rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 0 4rpx rgba(0,0,0,0.8);
}

.recipe-arrow {
  font-size: 32rpx;
  color: #e8d5a3;
  margin: 0 24rpx;
}

.recipe-result {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-icon {
  width: 70rpx;
  height: 70rpx;
}

/* 描述 */
.recipe-desc {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  padding: 0 20rpx 24rpx;
  font-style: italic;
}

/* 分类 & 解锁 */
.recipe-meta {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  padding: 20rpx 0;
  border-top: 2rpx solid rgba(232, 213, 163, 0.15);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #e8d5a3;
}

.meta-icon {
  width: 56rpx;
  height: 56rpx;
}

/* ==================== 物品详情弹窗 ==================== */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-container {
  width: 85%;
  max-height: 80vh;
  background-color: #2c2c2c;
  border-radius: 20rpx;
  border: 3rpx solid rgba(232, 213, 163, 0.4);
  overflow: hidden;
}

.popup-header {
  background-color: #3c3730;
  padding: 28rpx 0 20rpx;
  text-align: center;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.3);
}

.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #e8d5a3;
}

.popup-image-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 20rpx;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.15);
}

.popup-image {
  width: 200rpx;
  height: 200rpx;
}

.popup-icon {
  width: 80rpx;
  height: 80rpx;
  margin-top: 12rpx;
}

/* 弹窗分区标题 */
.popup-section-header {
  background-color: rgba(232, 213, 163, 0.1);
  padding: 14rpx 0;
  text-align: center;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.2);
  border-top: 2rpx solid rgba(232, 213, 163, 0.2);
}

.popup-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #e8d5a3;
}

/* 弹窗内配方 */
.popup-recipe-craft {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
}

.popup-ingredients {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.popup-ing {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-ing-icon {
  width: 60rpx;
  height: 60rpx;
}

.popup-ing-qty {
  position: absolute;
  bottom: 2rpx;
  right: 6rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 0 4rpx rgba(0, 0, 0, 0.8);
}

.popup-recipe-arrow {
  font-size: 28rpx;
  color: #e8d5a3;
  margin: 0 20rpx;
}

.popup-recipe-desc {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  padding: 0 20rpx 16rpx;
  font-style: italic;
}

.popup-recipe-meta {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(232, 213, 163, 0.1);
}

.popup-meta-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.popup-meta-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #e8d5a3;
}

.popup-meta-icon {
  width: 48rpx;
  height: 48rpx;
}

.popup-unlock {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 0 0 16rpx;
}

/* 掉落/生成来源网格 */
.popup-source-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
}

.popup-source-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.popup-source-icon {
  width: 64rpx;
  height: 64rpx;
}

.popup-source-name {
  font-size: 18rpx;
  color: #ccc;
  margin-top: 6rpx;
  text-align: center;
  word-break: break-all;
}

/* 关闭按钮 */
.popup-close {
  padding: 24rpx 0;
  text-align: center;
  border-top: 2rpx solid rgba(232, 213, 163, 0.2);
  background-color: #3c3730;
}

.popup-close:active {
  background-color: rgba(232, 213, 163, 0.15);
}

.popup-close-text {
  font-size: 28rpx;
  color: #e8d5a3;
  font-weight: 500;
}
