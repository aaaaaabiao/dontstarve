<!--index.wxml-->
<scroll-view class="scrollarea" scroll-y type="list">
  <!-- 分类图标网格 -->
  <view class="category-grid">
    <view
      class="category-item {{selectedIndex === index ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="name"
      bindtap="onCategoryTap"
      data-index="{{index}}"
    >
      <image class="category-icon" src="{{item.image}}" mode="aspectFit" />
    </view>
  </view>

  <!-- 分类名称 -->
  <view class="section-title" wx:if="{{selectedName}}">
    <text class="section-title-text">{{selectedName}}</text>
  </view>

  <!-- 子分类图标行 -->
  <view class="sub-category-row" wx:if="{{subCategories.length > 0}}">
    <view
      class="sub-category-item {{selectedSubIndex === index ? 'sub-active' : ''}}"
      wx:for="{{subCategories}}"
      wx:key="image"
      bindtap="onSubCategoryTap"
      data-index="{{index}}"
    >
      <image class="sub-category-icon" src="{{item.image}}" mode="aspectFit" />
    </view>
  </view>

  <!-- 物品列表 -->
  <scroll-view class="items-scroll" scroll-y wx:if="{{items.length > 0}}">
    <view class="items-grid">
      <view class="item-cell {{selectedItem === item.name ? 'item-active' : ''}}" wx:for="{{items}}" wx:key="name" bindtap="onItemTap" data-name="{{item.name}}">
        <image class="item-icon" src="{{item.image}}" mode="aspectFit" />
        <text class="item-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 合成配方信息 -->
  <view class="recipe-panel" wx:if="{{recipeList.length > 0}}">
    <view class="recipe-card" wx:for="{{recipeList}}" wx:key="name" wx:for-item="recipe">
      <view class="recipe-header">
        <text class="recipe-header-text">制作配方</text>
      </view>

      <!-- 材料 > 产物 -->
      <view class="recipe-craft">
        <view class="recipe-ingredients">
          <view class="ingredient" wx:for="{{recipe.ingredients}}" wx:key="name" wx:for-item="ing" bindtap="onIngredientTap" data-name="{{ing.name}}">
            <image class="ingredient-icon" src="{{ing.image}}" mode="aspectFit" />
            <text class="ingredient-qty">{{ing.quantity}}</text>
          </view>
        </view>
        <text class="recipe-arrow">▶</text>
        <view class="recipe-result">
          <image class="result-icon" src="{{selectedItemImage}}" mode="aspectFit" />
          <text class="ingredient-qty">1</text>
        </view>
      </view>

      <!-- 描述 -->
      <text class="recipe-desc" wx:if="{{recipe.description}}">"{{recipe.description}}"</text>

      <!-- 分类 & 解锁 -->
      <view class="recipe-meta">
        <view class="meta-item" wx:if="{{recipe.category}}">
          <text class="meta-label">分类</text>
          <image class="meta-icon" src="{{recipe.category.image}}" mode="aspectFit" />
        </view>
        <view class="meta-item" wx:if="{{recipe.unlock}}">
          <text class="meta-label">解锁</text>
          <image class="meta-icon" src="{{recipe.unlock.image}}" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-spacer"></view>
  <tab-bar active="{{0}}"></tab-bar>
</scroll-view>

<!-- 物品详情弹窗（移到 scroll-view 外部，避免 fixed 定位异常） -->
<view class="popup-mask" wx:if="{{showPopup}}" bindtap="closePopup">
  <scroll-view class="popup-container" scroll-y catchtap="">
    <!-- 物品名称 + 图片 -->
    <view class="popup-header">
      <text class="popup-title">{{popupItem.name}}</text>
    </view>
    <view class="popup-image-wrap">
      <image class="popup-image" src="{{popupItem.image}}" mode="aspectFit" />
      <image class="popup-icon" src="{{popupItem.icon}}" mode="aspectFit" wx:if="{{popupItem.icon}}" />
    </view>

    <!-- 制作配方 -->
    <block wx:if="{{popupItem.recipes.length > 0}}">
      <view class="popup-section-header">
        <text class="popup-section-title">制作配方</text>
      </view>
      <view wx:for="{{popupItem.recipes}}" wx:key="name" wx:for-item="pr">
        <view class="popup-recipe-craft">
          <view class="popup-ingredients">
            <view class="popup-ing" wx:for="{{pr.ingredients}}" wx:key="name" wx:for-item="pi" bindtap="onPopupIngredientTap" data-name="{{pi.name}}">
              <image class="popup-ing-icon" src="{{pi.image}}" mode="aspectFit" />
              <text class="popup-ing-qty">{{pi.quantity}}</text>
            </view>
          </view>
          <text class="popup-recipe-arrow">▶</text>
          <view class="popup-ing">
            <image class="popup-ing-icon" src="{{popupItem.icon || popupItem.image}}" mode="aspectFit" />
            <text class="popup-ing-qty">1</text>
          </view>
        </view>
        <text class="popup-recipe-desc" wx:if="{{pr.description}}">"{{pr.description}}"</text>
        <view class="popup-recipe-meta">
          <view class="popup-meta-item" wx:if="{{pr.category}}">
            <text class="popup-meta-label">分类</text>
            <image class="popup-meta-icon" src="{{pr.category.image}}" mode="aspectFit" />
          </view>
          <view class="popup-meta-item" wx:if="{{pr.crafting_station}}">
            <text class="popup-meta-label">制作站</text>
            <image class="popup-meta-icon" src="{{pr.crafting_station.image}}" mode="aspectFit" />
          </view>
        </view>
        <text class="popup-unlock" wx:if="{{pr.unlock}}">({{pr.unlock.name}})</text>
        <text class="popup-unlock" wx:elif="{{!pr.unlock}}">（无法解锁配方）</text>
      </view>
    </block>

    <!-- 掉落自 -->
    <block wx:if="{{popupItem.drop_from.length > 0}}">
      <view class="popup-section-header">
        <text class="popup-section-title">掉落自</text>
      </view>
      <view class="popup-source-grid">
        <view class="popup-source-item" wx:for="{{popupItem.drop_from}}" wx:key="name">
          <image class="popup-source-icon" src="{{item.image}}" mode="aspectFit" />
          <text class="popup-source-name">{{item.name}}</text>
        </view>
      </view>
    </block>

    <!-- 生成自 -->
    <block wx:if="{{popupItem.generated_from.length > 0}}">
      <view class="popup-section-header">
        <text class="popup-section-title">生成自</text>
      </view>
      <view class="popup-source-grid">
        <view class="popup-source-item" wx:for="{{popupItem.generated_from}}" wx:key="name">
          <image class="popup-source-icon" src="{{item.image}}" mode="aspectFit" />
          <text class="popup-source-name">{{item.name}}</text>
        </view>
      </view>
    </block>

    <!-- 关闭按钮 -->
    <view class="popup-close" bindtap="closePopup">
      <text class="popup-close-text">关闭</text>
    </view>
  </scroll-view>
</view>
