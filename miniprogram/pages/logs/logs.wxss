page {
  height: 100vh;
  background-color: #2c2c2c;
}

.scrollarea {
  height: 100vh;
}

.items-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 20rpx 24rpx;
}

.item-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
}

.item-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
}

.item-name {
  font-size: 22rpx;
  color: #e8d5a3;
  margin-top: 10rpx;
  text-align: center;
  word-break: break-all;
}

.sub-section {
  margin-bottom: 20rpx;
}

.sub-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid rgba(232, 213, 163, 0.2);
}

.sub-icon {
  width: 64rpx;
  height: 64rpx;
}
