.nav-bar-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background-color: #2c2c2c;
  border-bottom: 2rpx solid rgba(232, 213, 163, 0.2);
}

.status-bar {
  width: 100%;
}

.nav-bar-content {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #e8d5a3;
}

.version-switch {
  display: flex;
  align-items: center;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 32rpx;
  border: 2rpx solid rgba(232, 213, 163, 0.3);
  padding: 4rpx;
}

.switch-btn {
  padding: 4rpx 20rpx;
  border-radius: 28rpx;
  transition: all 0.3s ease;
}

.switch-btn.active {
  background-color: #e8d5a3;
}

.switch-btn text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

.switch-btn.active text {
  color: #2c2c2c;
  font-weight: bold;
}
