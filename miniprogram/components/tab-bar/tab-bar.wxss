.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  height: 100rpx;
  background-color: #1a1a1a;
  border-top: 1rpx solid rgba(232, 213, 163, 0.15);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-item:active {
  opacity: 0.7;
}

.tab-text {
  font-size: 28rpx;
  color: #999;
}

.tab-item.active .tab-text {
  color: #e8d5a3;
  font-weight: bold;
}
